# 环境变量模板 - 复制为 .env.local 并填入实际值

# Acedata AI 服务 (必填) - https://platform.acedata.cloud
ACEDATA_API_KEY=sk-your-acedata-key-here

# Twitter API - twitterapi.io (必填) - https://twitterapi.io
TWITTER_API_KEY=your-twitter-api-key

# Resend Email (可选，不配置则仅使用浏览器通知) - https://resend.com
RESEND_API_KEY=re_your-resend-key

# 通知邮箱 (可选)
NOTIFY_EMAIL=your@email.com
